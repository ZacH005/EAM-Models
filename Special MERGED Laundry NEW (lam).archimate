    <element xsi:type="archimate:DataObject" name="Open Account" id="id-5b0f197ef5f64c1a8e9067f71e6610e6">
      <documentation>The physical database structure or schema inside the Hotel Management System (HMS) where financial transactions are stored digitally.&#xD;
&#xD;
Internal Memo Section: Mentioned in the context of reservation handling, upgrades, and room check-outs where outstanding costs are processed and updated automatically.&#xD;
&#xD;
Smart Wash Ecosystem (Laundry Text): Located within the laundry ecosystem documentation, describing the process where automated equipment triggers usage metrics and securely transfers laundry charges straight to the guest's open account.&#xD;
&#xD;
Transfer Service Section: Found under the transit logistics and scheduling text, explaining how vehicle bookings and driver assignments calculate final transit fees and append them directly to the open account ledger.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Staff Portal Application" id="id-cadf5b6d698f43158a9a8e97077c0763"/>
    <element xsi:type="archimate:ApplicationInterface" name="Staff Portal Dashboard" id="id-20d1b6574e8541aba638c0a7a85d628e">
      <documentation>Everything is displayed on the staff portal dashboard for the employees to see.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Hotel Management System (HMS)" id="id-9394ba3905cb472f93fb22d1048223de"/>
    <element xsi:type="archimate:ApplicationFunction" name="Update Associated Costs Automatically" id="id-60f3bf954e9f4dfda68a022a44910cf9">
      <documentation>Monitors modifications to the reservation and performs a Write Access connection down into the Open Account data object</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Generate Briefing Report" id="id-c1b076f96f0746c7aae77ae2abddff16">
      <documentation>Automatically compiles daily operations across multiple departments and runs a background Read Access query against active Special Request data objects.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Transfer Management System (TMS) " id="id-f61e50c70b3242729d70190eafccd721"/>
    <element xsi:type="archimate:DataObject" name="Transfer Schedule" id="id-10842d3b142f4146a453404b7937cab6">
      <documentation>Tracks real-time active transit timelines.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Match Requests with Vehicle" id="id-a116ebf3ed1b4de586ad79ed7e205248">
      <documentation>An algorithmic capability evaluating passenger counts, car capacity, and luggage space to determine the best fleet options.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Submit Transfer Requests" id="id-289c5ed0b90645a2a189691273cff66b">
      <documentation>Handles the initial ingestion of transfer parameters from the concierge client.</documentation>
