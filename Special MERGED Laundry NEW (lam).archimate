  <folder name="Technology &amp; Physical" id="id-cadf53a747e64a7db56b107538a8d64d" type="technology">
    <element xsi:type="archimate:Device" name="Smartphone " id="id-186c8f3fd04743c3bece4e1e70d60894"/>
    <element xsi:type="archimate:CommunicationNetwork" name="Hotel Wi-Fi Network" id="id-453b4c97cf1645c4a09d809ab803cb96">
      <documentation>he wireless network mesh deployed across the ArchiHotel premises. It provides the secure, local data highway for guest-facing teams.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="WeWash Server" id="id-40abb90ec07b4a33a35046bd9f15e360">
      <documentation>It hosts the external WeWash Platform application component</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Hotel Fleet Vehicles" id="id-bedc2eb25d9c486db783b0fa553d319e">
      <documentation>The physical automotive transport assets (shuttles, luxury cars) used to execute airport pick-ups, departure transfers, and destination transits.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Central Server" id="id-112aba1b7d8247e6bbc59e50317b1965">
      <documentation>This is the primary cloud-based backend hardware engine for the hotel. It provides the core compute power, processing memory, and database storage needed to run the logical modules of the Hotel Management System (HMS Core Engine) and the Transfer Management System (TMS).</documentation>
    </element>
