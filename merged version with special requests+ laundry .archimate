    <element xsi:type="archimate:BusinessObject" name="Scheduled Pickup Time" id="id-9dc3c1a277494585afad091fba0a9b9c"/>
    <element xsi:type="archimate:BusinessObject" name="In-room Preparation Request" id="id-fe5d46b1eb3340d79c5080039fb82f9b"/>
    <element xsi:type="archimate:BusinessObject" name="Housekeeping ToDos" id="id-68efaa0831a84e4ab1c6eb5caa1b2501"/>
    <element xsi:type="archimate:BusinessObject" name="Housekeeping Priorities" id="id-823b78c597534614a955a2216703dd98"/>
  </folder>
  <folder name="Application" id="id-1e9741fcdfbc4f14aed7ed9c701be9a0" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Hotel Management System" id="id-55f8d01cbf3f4c899cc79361e9353302">
      <documentation>Central HMS platform storing reservations, guest accounts, briefing reports, open costs, and service charges.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Staff Portal Application" id="id-5e8fe1303e3148c0951ee178f6c680e2">
      <documentation>Mobile staff application used for operational dashboard, coordination, tasks, VIP arrivals, and special requests.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="Staff Portal Dashboard" id="id-0fe11e9787c04cf6863fa5437eac74d4">
      <documentation>Dashboard interface for staff to see briefing reports, VIPs, housekeeping tasks, transfer schedule, and special requests.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="WeWash Application" id="id-b30c9e6da35f4b27bb4d3cc8b14010d3">
      <documentation>Guest-facing laundry reservation application.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="WeWash Platform" id="id-98f9d806fdf1438980a3571fb5601e4a">
      <documentation>External laundry platform coordinating reservation, waiting list, machine activation, and charge transfer.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="WeWash App Interface" id="id-bd83cdafcdbc491fab169e0e95630518">
      <documentation>Guest-facing interface used to reserve washing machines and select programs.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="Washing Machine Interface" id="id-7976bd5033d64582b37bf69d82f12f0f">
      <documentation>Application-layer software interface on the washer-dryer used to select/start the assigned program.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Transfer Management System" id="id-9652e1051a1f43a58add1ba840674f5e">
      <documentation>Application component for transfer request processing, driver/vehicle matching, and transfer cost handling.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="External Car Booking Platform" id="id-4f0ee43b773a4f6186da339d1e42710b">
      <documentation>External platform used when hotel fleet vehicles are unavailable.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="External Booking Platform" id="id-4eca447e055d4ba99b454690aab2963e">
      <documentation>External booking channel connected to reservations and special requests.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Provide Operational Dashboard" id="id-0bc761da9dbb4285a063803ffaad0d60">
      <documentation>Application service aggregating briefing, special requests, housekeeping, VIPs, and transfers.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Distribute Push Notifications" id="id-8df8da1e91ff47e88487e8d081d6978a">
      <documentation>Application service for urgent guest/staff updates and confirmations.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Reserve Washing Machine" id="id-0dac8c2afc5e44d0a731a2a01622043a">
      <documentation>Laundry reservation service performed through WeWash.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Notify Driver Automatically" id="id-792b036656b74036af89aba59db8a58a">
      <documentation>Driver notification service containing pickup location and scheduled time.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Add Services to Reservation" id="id-c861cc840a1d4193946a2aae3a8ef9ea">
      <documentation>Adds laundry, transfer, upgrades, or special requests to guest reservation.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Update Open Account" id="id-5511ef3412234b428630391aee05c4f8">
      <documentation>Updates guest account with service charges.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Generate Briefing Report" id="id-b8c850f6ffd845d18b3c7e6059df7ff9">
      <documentation>Compiles arrivals, guest information, VIP list, special requests, and operational updates.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Display Briefing Report" id="id-195126cc57b44bcf9a81e0c63a9adcb0">
      <documentation>Displays generated briefing report in the staff portal.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Review VIP Arrivals" id="id-8ab0b2ec1f764bbdb4f2a73228e14b02">
      <documentation>Application-supported review of VIP arrivals.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Manage Housekeeping ToDos" id="id-b36f781f5aef460798e925ef6977a99e">
      <documentation>Displays and manages housekeeping tasks and priorities.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Broadcast Coordination" id="id-fc82a01208fc4f358d249d78912a55c6">
      <documentation>Sends cross-departmental coordination updates to staff.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Check Machine Availability" id="id-9bc6986dfa1d41b5be4a86a646ea031d">
      <documentation>Checks washer-dryer availability in the WeWash platform.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Assign Machine to Guest" id="id-a81a850612ba48f8b74366e9835f565c">
      <documentation>Assigns a free washer-dryer to the guest reservation.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Manage Laundry Waiting List" id="id-82cbfd25332d496195adacf9a4c556d7">
      <documentation>Maintains waiting list when all machines are occupied.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Confirm Laundry Reservation by Push Notification" id="id-44b565e0ea1e4f20b3144e122dc6428c">
      <documentation>Notifies guest when machine is assigned or available.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Activate Assigned Machine at Scheduled Time" id="id-86a0a76dbea740c3a3419fbeea75899d">
      <documentation>Triggers scheduled washer-dryer activation.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Calculate Laundry Cost Based on Program" id="id-94752390372a4238bfe4e7f9aa44c838">
      <documentation>Calculates cost using selected laundry program.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Record Laundry Service as Additional Charge" id="id-76bf74780bd34e5485010a7ac3f6276a">
      <documentation>Records laundry usage as a charge.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Transfer Laundry Charges to HMS" id="id-bfd0bbf1d5784a0f83306135f1c213a6">
      <documentation>Securely transfers WeWash charge data to HMS.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Submit Transfer Request" id="id-284f4f6752ce4e5592a95adee5e96708">
      <documentation>Concierge submits request parameters into TMS.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Check Available Drivers and Vehicles" id="id-8637913bede74deeb6b3ad6def724ff3">
      <documentation>Checks driver and fleet availability in real time.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Match Request with Driver/Vehicle" id="id-b81b49d370394211b2698df54d940354">
      <documentation>Matches transfer request with suitable driver/vehicle based on capacity, type, and luggage.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Assign Driver and Vehicle" id="id-e64ff873e9564f40ae56e7b8cc7edb11">
      <documentation>Assigns selected driver and vehicle to transfer request.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Connect to External Car Booking Platform" id="id-3bed714611c84a52a70ba79a95f4f3a8">
      <documentation>Connects to external platform when hotel fleet is unavailable.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Calculate Transfer Cost" id="id-23e702031ba0491785be525b62b6858b">
      <documentation>Calculates transfer cost from pickup and vehicle details.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Add Transfer Cost to Open Account" id="id-18c0cb02c4b54b47a57c5a702f12dae6">
      <documentation>Adds transfer cost to guest open account.</documentation>
    </element>
