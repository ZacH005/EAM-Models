<?xml version='1.0' encoding='UTF-8'?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:archimate="http://www.archimatetool.com/archimate" name="ArchiHotel Special Requests + Laundry - Merged Nested Model" id="id-a0c0bda9aa0244b48df83a0ba94b58bb" version="5.0.0">
  <folder name="Strategy" id="id-3dadd20ec2b64f64abdf477f36952222" type="strategy"/>
  <folder name="Business" id="id-feda14011af543e48d17f30b905897ff" type="business">
    <element xsi:type="archimate:BusinessActor" name="ArchiHotel Group" id="id-a03b9756151c42b8a171303a39e2fcf5">
      <documentation>Overall enterprise responsible for guest-facing hotel services.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Guest" id="id-d1353bd2ad5342ccb2aa18dd5426c682">
      <documentation>Main external customer role.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="VIP Guest" id="id-23fb65de51d848fb914e767c1fe4a8fb">
      <documentation>Specialized guest status used for VIP arrivals and services.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Concierge Team" id="id-452808d7dfb6499699e336c570d654ce">
      <documentation>Coordinates special requests, transfer support, and fallback handling.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Housekeeping Team" id="id-bdd5da82d3ee48d0b88363bf34decfef">
      <documentation>Supports in-room preparation and housekeeping tasks.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Driver" id="id-c534381f134d411f95d10167eb08c21c">
      <documentation>Executes assigned transfer bookings.</documentation>
    </element>
    <element xsi:type="archimate:BusinessActor" name="External Service Provider" id="id-b1eac893583044eb8e048c93bcab8cb8">
      <documentation>Merged external provider for cleaning and car-rental fallback cases.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Special Request Handling" id="id-aefef9cb9ac447949b3ea8612aa0354f">
      <documentation>Umbrella guest-facing service for laundry, transfer, VIP, in-room, and fallback requests.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Laundry Service" id="id-0bc24a52155a46b7a6ac552f53fc66b6">
      <documentation>Smart Wash/self-service laundry capability.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Transfer Service" id="id-6d30d107bc5141e49e97cc56d65b7c76">
      <documentation>Airport pickup, departure transfer, and destination transfer capability.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="VIP Services" id="id-9cb1cd3a90c34670b046900bfff5e698">
      <documentation>Special service package for VIP guests.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="In-room Preparations" id="id-28f79681a0c244a6a27431f5f898a6c1">
      <documentation>Preparation of guest rooms with amenities or requested items.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Address Special Requests by Guest" id="id-9739da547b3443b2beac2567b6c460f5">
      <documentation>Main business process for accepting and coordinating special requests.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Self-service Laundry Reservation" id="id-df5e0dd5c0df4dd99105e5764dc90fab">
      <documentation>Guest reserves washing machine and uses laundry service.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Wash / Dry / Combined Cycle Selection" id="id-d97c0b7a223a4f628f32aef32ac69010">
      <documentation>Guest chooses wash, dry, or combined washer-dryer program.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Start Washing Machine" id="id-1813af4eb0d14b00b7bce439c151ae8c">
      <documentation>Guest starts the assigned washer-dryer at the scheduled time.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Transfer Request Handling" id="id-7ac481792fd443a1b98a2f1380d7e42f">
      <documentation>Concierge captures and manages a guest transfer request.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Driver and Vehicle Assignment" id="id-20e961d45031401fa0df70a18916c693">
      <documentation>Hotel assigns a suitable driver and vehicle.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="External Vehicle Procurement" id="id-04ecb949fa2b497586173d98567e3780">
      <documentation>Fallback procurement of an external rental vehicle.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Concierge Transfer Fulfillment" id="id-00afcb0b92464eaf94b34800f5722e56">
      <documentation>Fallback case where concierge fulfills transfer when no driver is available.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Exceptional External Cleaning Handling" id="id-48c6dd6454d244809a8e7c7385e787b5">
      <documentation>Manual fallback for exceptional cleaning/laundry requests.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Fulfill In-House Requests" id="id-7bb97e9d7f3a4614b5ca899cd279f3d3">
      <documentation>Internal fulfillment of standard and VIP requests such as amenities, late checkout, or champagne.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Daily Operational Briefing" id="id-74f8cb126f504961af28dc3fdbf158ff">
      <documentation>Morning coordination process across hotel operations.</documentation>
    </element>
    <element xsi:type="archimate:BusinessInteraction" name="Operational Coordination" id="id-1b4d04c4c0114b2585633b7fa232f0bd">
      <documentation>Cross-departmental coordination among concierge, housekeeping, drivers, and management.</documentation>
    </element>
