  <folder name="Technology &amp; Physical" id="id-19a63aeb700e4cfbae193a8237c8f96c" type="technology">
    <element xsi:type="archimate:Node" name="Central Server" id="id-ff75b58b34f1421eaf1b6659b570c8ea">
      <documentation>Cloud-based backend hosting HMS, Staff Portal, TMS, website components, and operational data.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="WeWash Server" id="id-f566c42e321943519de0992552bc91f0">
      <documentation>Server hosting WeWash platform and laundry waiting list.</documentation>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Hotel Wi-Fi Network" id="id-d6ebdfc2b44543a79dcf4ab2b68276a9">
      <documentation>Merged hotel network/Wi-Fi infrastructure used for synchronization and secure charge transfer.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Guest Smartphone" id="id-fad0b037a0604f4089f00f25e39d30e2">
      <documentation>Guest device running the WeWash application.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Android Smartphones / Staff Phones" id="id-aa9c703ec0914a15a628d317750d4811">
      <documentation>Staff devices running the Staff Portal Application.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Washing Machines / Integrated Washer-Dryers" id="id-47acfd70c71f445284b6a93d1bfec72a">
      <documentation>Physical washer-dryer devices reserved and started by guests.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Door Card Reader" id="id-43c04f2acb5f4e79b56ceb6d4ac4fd3b">
      <documentation>Reader checking key card access at laundry room or guest-room doors.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Key Card" id="id-94ae12436a954221af3b95af845cd1c3">
      <documentation>Guest/staff key card carrying access authorization.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Key Card Door System Software" id="id-0d948408ca3e48538a390f08ff91674c">
      <documentation>Technology-layer software verifying key-card access and unlocking doors.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyFunction" name="Key Card Authorization for Laundry Room" id="id-2f0b769d526c4da1a1ba052e66cc17cb">
      <documentation>Verifies whether key card allows laundry-room entry.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyFunction" name="Door Unlocking" id="id-c8e01c8503f14b688f76f25a3116cbe3">
      <documentation>Unlocks door after confirmed authorization.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyFunction" name="Program Selection on Machine" id="id-eb45602f39a642adbee45ddd4659fec1">
      <documentation>Physical-device behavior for selecting/starting cycle at the machine.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyProcess" name="Washing / Drying / Combined Cycle Execution" id="id-6c31060bcc2e4da39eff550759a9bdea">
      <documentation>Physical execution of wash, dry, or combined cycle.</documentation>
    </element>
