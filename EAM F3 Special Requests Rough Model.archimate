  <folder name="Strategy" id="id-d0d6ac2c41744d898892e503a1cf3e9d" type="strategy"/>
  <folder name="Business" id="id-486f2acd739d436f96fa22ac1e1b686b" type="business">
    <element xsi:type="archimate:BusinessRole" name="Concierge" id="id-4d221a62d6024cddbe75825826447d46"/>
    <element xsi:type="archimate:BusinessActor" name="External Cleaning Service " id="id-a2314879bcdf4781b3409e8d0b61a31b"/>
    <element xsi:type="archimate:BusinessProcess" name="Address Special Requests by Guests" id="id-841e84c8b1594a149b1c817ed8aa5eee"/>
    <element xsi:type="archimate:BusinessProcess" name="Special Request handling" id="id-ba00efa1318c46c5a46beb144896aee2"/>
    <element xsi:type="archimate:BusinessService" name="Laundry Service" id="id-81b7916b51fa40cdb005450f739fe725"/>
    <element xsi:type="archimate:BusinessService" name="Transfer Service" id="id-4bbac0b7e22f4210903482e757905ba0"/>
    <element xsi:type="archimate:BusinessObject" name="Briefing Report" id="id-fb859793bbac4d78aee5231db9bde564"/>
    <element xsi:type="archimate:BusinessObject" name="Special Requests" id="id-a2e665b32e9a42328c5fd198969f6549"/>
    <element xsi:type="archimate:BusinessObject" name="Transfer Arrangements" id="id-f0bd505078714e08b3eff3a79e7bf5aa"/>
    <element xsi:type="archimate:BusinessRole" name="Guest" id="id-503b58776c974a23bb86049521a72635"/>
    <element xsi:type="archimate:BusinessObject" name="Guest Reservation" id="id-1fcda5b4164d496da1272d18b933cc7c"/>
    <element xsi:type="archimate:BusinessProcess" name="Exceptional External Cleaning Process" id="id-d3e40ff8dc544632823cea478081d262"/>
    <element xsi:type="archimate:BusinessProcess" name="Fulfill In-House Requests (Standard &amp; VIP)" id="id-2034fb33b40248e190439fcbe50fd7f1">
      <documentation>Handles internal fulfillment of in-room setups, amenities, and special preferences for both standard guests (e.g., extra pillows, late check-out) and VIP guests (e.g., complimentary champagne, fruit platters) prior to or during their stay.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Open Account" id="id-2958c694cef84d9bb102c5bf41cf6e05">
      <documentation>Conceptual operational ledger used by the hotel staff to track charges associated with a guest's stay</documentation>
    </element>
  </folder>
  <folder name="Application" id="id-70b47308177c4dceaabceb77a3611b17" type="application">
    <element xsi:type="archimate:ApplicationInterface" name="Application Interface" id="id-492e28dc78fc46c3993ef3ee2ec4394f"/>
    <element xsi:type="archimate:ApplicationProcess" name="Add Services to Reservation" id="id-abe32fc1142143a29e997bd91db1be77"/>
    <element xsi:type="archimate:DataObject" name="Special Requests" id="id-91986f7d113d40f99cfee487c15174b2"/>
    <element xsi:type="archimate:ApplicationComponent" name="External Booking Platform" id="id-a0b6fb2dd9a14071a3679b751fbc2500"/>
    <element xsi:type="archimate:DataObject" name="Guess Reservation" id="id-9bb43fc665d94db1b56f94b59847f368"/>
    <element xsi:type="archimate:ApplicationFunction" name="Display Briefing Report" id="id-feae05fe6e0e4f5f862b8aa4f02d87c3"/>
    <element xsi:type="archimate:DataObject" name="Open Account" id="id-5b0f197ef5f64c1a8e9067f71e6610e6">
      <documentation>The physical database structure or schema inside the Hotel Management System (HMS) where financial transactions are stored digitally.&#xD;
&#xD;
Internal Memo Section: Mentioned in the context of reservation handling, upgrades, and room check-outs where outstanding costs are processed and updated automatically.&#xD;
&#xD;
Smart Wash Ecosystem (Laundry Text): Located within the laundry ecosystem documentation, describing the process where automated equipment triggers usage metrics and securely transfers laundry charges straight to the guest's open account.&#xD;
&#xD;
Transfer Service Section: Found under the transit logistics and scheduling text, explaining how vehicle bookings and driver assignments calculate final transit fees and append them directly to the open account ledger.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Staff Portal Application" id="id-cadf5b6d698f43158a9a8e97077c0763"/>
    <element xsi:type="archimate:ApplicationInterface" name="Staff Portal Dashboard" id="id-20d1b6574e8541aba638c0a7a85d628e">
      <documentation>Everything is displayed on the staff portal dashboard for the employees to see.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Hotel Management System (HMS)" id="id-9394ba3905cb472f93fb22d1048223de"/>
    <element xsi:type="archimate:ApplicationFunction" name="Update Associated Costs Automatically" id="id-60f3bf954e9f4dfda68a022a44910cf9">
      <documentation>Monitors modifications to the reservation and performs a Write Access connection down into the Open Account data object</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Generate Briefing Report" id="id-c1b076f96f0746c7aae77ae2abddff16">
      <documentation>Automatically compiles daily operations across multiple departments and runs a background Read Access query against active Special Request data objects.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Transfer Management System (TMS) " id="id-f61e50c70b3242729d70190eafccd721"/>
    <element xsi:type="archimate:DataObject" name="Transfer Schedule" id="id-10842d3b142f4146a453404b7937cab6">
      <documentation>Tracks real-time active transit timelines.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Match Requests with Vehicle" id="id-a116ebf3ed1b4de586ad79ed7e205248">
      <documentation>An algorithmic capability evaluating passenger counts, car capacity, and luggage space to determine the best fleet options.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Submit Transfer Requests" id="id-289c5ed0b90645a2a189691273cff66b">
      <documentation>Handles the initial ingestion of transfer parameters from the concierge client.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="WeWash External Platform" id="id-a859d7dcff9c4a769c340fc4225a0f68"/>
    <element xsi:type="archimate:ApplicationProcess" name="Transfer Laundry Charges to HMS " id="id-9a5e7c9827b04398a7e8bee3393f559d"/>
    <element xsi:type="archimate:DataObject" name="Briefing Report" id="id-8798cf68cf0342fe8759e32bf5b23f7e"/>
  </folder>
  <folder name="Technology &amp; Physical" id="id-cadf53a747e64a7db56b107538a8d64d" type="technology">
    <element xsi:type="archimate:Device" name="Smartphone " id="id-186c8f3fd04743c3bece4e1e70d60894"/>
    <element xsi:type="archimate:CommunicationNetwork" name="Hotel Wi-Fi Network" id="id-453b4c97cf1645c4a09d809ab803cb96">
      <documentation>he wireless network mesh deployed across the ArchiHotel premises. It provides the secure, local data highway for guest-facing teams.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="WeWash Server" id="id-40abb90ec07b4a33a35046bd9f15e360">
      <documentation>It hosts the external WeWash Platform application component</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Hotel Fleet Vehicles" id="id-bedc2eb25d9c486db783b0fa553d319e">
      <documentation>The physical automotive transport assets (shuttles, luxury cars) used to execute airport pick-ups, departure transfers, and destination transits.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Central Server" id="id-112aba1b7d8247e6bbc59e50317b1965">
      <documentation>This is the primary cloud-based backend hardware engine for the hotel. It provides the core compute power, processing memory, and database storage needed to run the logical modules of the Hotel Management System (HMS Core Engine) and the Transfer Management System (TMS).</documentation>
    </element>
  </folder>
