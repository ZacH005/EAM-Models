    <!-- CROSS-LAYER: App serves Business -->
    <element xsi:type="archimate:ServingRelationship" id="r-40" source="a-wewash-ui" target="b-guest"/>
    <element xsi:type="archimate:ServingRelationship" id="r-41" source="a-wewash-app" target="b-submit"/>
